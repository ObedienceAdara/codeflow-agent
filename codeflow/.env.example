# CodeFlow Agent Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# LLM Configuration (Default: Groq)
# ===========================================
# Supported providers: groq, anthropic, openai
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-70b-versatile
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# API Keys for LLM Providers (set the one matching your provider)
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# Web Search Configuration (Tavily)
# Required for Architect, DevOps, QA, and Reviewer agents
# ===========================================
TAVILY_API_KEY=your_tavily_api_key_here
# Search result limit per query (default: 5)
TAVILY_SEARCH_DEPTH=medium
# Cache TTL in seconds (default: 3600 = 1 hour)
TAVILY_CACHE_TTL=3600

# ===========================================
# Git Configuration
# ===========================================
GIT_DEFAULT_BRANCH=main
GIT_BRANCH_PREFIX=feature/
GIT_USER_NAME=CodeFlow Agent
GIT_USER_EMAIL=codeflow@local.dev

# ===========================================
# Project Settings
# ===========================================
PROJECT_NAME=my-project
PROJECT_ROOT=.

# ===========================================
# Feature Flags
# ===========================================
# Enable automatic test generation and execution
ENABLE_AUTO_TESTING=true
# Enable automatic refactoring suggestions (use with caution)
ENABLE_AUTO_REFACTOR=false
# Enable security scanning in QA and Reviewer agents
ENABLE_SECURITY_SCANNING=true
# Enable web search for unknown technologies
ENABLE_WEB_SEARCH=true
# Enable diff-only protocol for token optimization
ENABLE_DIFF_PROTOCOL=true
# Enable consensus loop for iterative agent collaboration
ENABLE_CONSENSUS_LOOP=true

# ===========================================
# Monitoring & Logging
# ===========================================
MONITORING_ENABLED=true
LOG_LEVEL=INFO
# Log file path (leave empty for stdout only)
LOG_FILE=codeflow.log

# ===========================================
# Performance & Optimization
# ===========================================
# Maximum context window size (tokens)
MAX_CONTEXT_SIZE=8192
# Enable lazy context loading (recommended for large codebases)
LAZY_CONTEXT_LOADING=true
# Vector store path for semantic code search (optional)
VECTOR_STORE_PATH=.codeflow/vector_store
