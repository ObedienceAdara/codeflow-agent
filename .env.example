# Environment Configuration for CodeFlow Agent

# LLM Provider Configuration
# Choose one: anthropic, openai, google, ollama
LLM_PROVIDER=anthropic

# Anthropic API (recommended for best performance)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# OpenAI API (alternative)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Google Vertex AI (alternative)
GOOGLE_PROJECT_ID=your_project_id
GOOGLE_LOCATION=us-central1
GOOGLE_MODEL=gemini-pro

# Ollama Local Models (for offline use)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Vector Database Configuration
CHROMA_DB_PATH=./.codeflow/chroma_db
CHROMA_COLLECTION=codeflow_embeddings

# Neo4j Graph Database (optional, for advanced code relationships)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Docker Configuration
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_SANDBOX_IMAGE=codeflow-sandbox:latest
DOCKER_TIMEOUT=300
DOCKER_MEMORY_LIMIT=2g
DOCKER_CPU_LIMIT=2

# Git Configuration
GIT_AUTHOR_NAME=CodeFlow Agent
GIT_AUTHOR_EMAIL=codeflow@localhost
GIT_AUTO_BRANCH=true
GIT_AUTO_COMMIT=false
GIT_REQUIRE_REVIEW=true

# Execution Limits
MAX_ITERATIONS=10
MAX_TOKENS_PER_CALL=4096
CONCURRENT_AGENTS=3
TASK_TIMEOUT=600

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./.codeflow/codeflow.log
ENABLE_AUDIT_LOG=true

# API Server Configuration
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=false
API_CORS_ORIGINS=["http://localhost:3000"]

# Security
ENCRYPTION_KEY=your_encryption_key_here_min_32_chars
SESSION_TIMEOUT=3600
MAX_FAILED_AUTH=5

# Monitoring and Telemetry
ENABLE_TELEMETRY=false
PROMETHEUS_PORT=9090
SENTRY_DSN=

# Feature Flags
ENABLE_AUTO_REFACTOR=true
ENABLE_AUTO_DEPLOY=false
ENABLE_INCIDENT_RESPONSE=true
ENABLE_DEPENDENCY_UPDATES=true
