# ============================================================
# CodeFlow Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Or use the interactive /setup command in the REPL instead.
# ============================================================

# ---- LLM Provider ----
# Choose one: groq, anthropic, openai, google, ollama
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Set the API key for your chosen provider:
GROQ_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# (Ollama requires no API key — install from ollama.com and run: ollama serve)

# ---- Database (ChromaDB for embeddings) ----
DB_CHROMA_PATH=./.codeflow/chroma_db
DB_CHROMA_COLLECTION=codeflow_embeddings

# Neo4j (optional — for code relationships)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=

# ---- Docker Sandbox ----
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_SANDBOX_IMAGE=codeflow-sandbox:latest
DOCKER_TIMEOUT=300
DOCKER_MEMORY_LIMIT=2g
DOCKER_CPU_LIMIT=2.0

# ---- Git ----
GIT_AUTHOR_NAME=CodeFlow Agent
GIT_AUTHOR_EMAIL=codeflow@localhost
GIT_AUTO_BRANCH=true
GIT_AUTO_COMMIT=false
GIT_REQUIRE_REVIEW=true
GIT_BRANCH_PREFIX=codeflow/

# ---- Execution Limits ----
MAX_ITERATIONS=10
CONCURRENT_AGENTS=3
TASK_TIMEOUT=600
RETRY_ATTEMPTS=3
RETRY_DELAY=1.0

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./.codeflow/codeflow.log
LOG_ENABLE_AUDIT=true

# ---- API Server ----
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=false

# ---- Feature Flags ----
ENABLE_AUTO_REFACTOR=true
ENABLE_AUTO_DEPLOY=false
ENABLE_INCIDENT_RESPONSE=true
ENABLE_DEPENDENCY_UPDATES=true
ENABLE_TELEMETRY=false
